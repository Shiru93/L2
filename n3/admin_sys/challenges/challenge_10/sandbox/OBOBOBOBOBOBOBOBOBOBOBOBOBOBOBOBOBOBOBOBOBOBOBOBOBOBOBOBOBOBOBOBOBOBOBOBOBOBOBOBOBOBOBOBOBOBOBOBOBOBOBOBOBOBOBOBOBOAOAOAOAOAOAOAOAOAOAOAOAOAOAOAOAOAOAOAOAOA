       [1mhostname [22m[[1m-b|--boot[22m] [[1m-F|--file filename[22m] [[1mhostname[22m]
       [1mhostname [22m[[1m-h|--help[22m] [[1m-V|--version[22m]

       [1mdomainname [22m[[1mnisdomain[22m] [[1m-F file[22m]
       [1mypdomainname [22m[[1mnisdomain[22m] [[1m-F file[22m]
       [1mnisdomainname [22m[[1mnisdomain[22m] [[1m-F file[22m]

